[Unit]
Description=LLM Gateway - OpenAI-compatible proxy for on-demand model serving
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=%LLM_USER%
Group=%LLM_USER%
Environment=HOME=%LLM_HOME%
Environment=PATH=%LLM_PATH%
WorkingDirectory=/etc/llm-gateway
ExecStart=/usr/local/bin/llm-gateway

# --- GPU & Memory Permissions ---
SupplementaryGroups=render video
LimitMEMLOCK=infinity

# NVIDIA CUDA access (optional — ignored when no NVIDIA GPU present)
DeviceAllow=/dev/nvidia0 rw
DeviceAllow=/dev/nvidiactl rw
DeviceAllow=/dev/nvidia-modeset rw
DeviceAllow=/dev/nvidia-uvm rw
DeviceAllow=/dev/nvidia-uvm-tools rw
DeviceAllow=/dev/nvidia-caps/* rw

# AMD/Intel DRI access (used by 8845HS 780M and Dell Intel iGPU)
DeviceAllow=/dev/dri/renderD128 rw
DeviceAllow=/dev/dri/renderD129 rw
DeviceAllow=/dev/dri/card0 rw
DeviceAllow=/dev/dri/card1 rw
# --------------------------------

Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
